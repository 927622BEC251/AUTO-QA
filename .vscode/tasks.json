{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven: Clean Build",
      "type": "shell",
      "command": "mvn",
      "args": ["clean", "install"],
      "problemMatcher": ["$java"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Maven: Run All Tests",
      "type": "shell",
      "command": "mvn",
      "args": ["clean", "test"],
      "problemMatcher": ["$java"],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Maven: Run LoginTest",
      "type": "shell",
      "command": "mvn",
      "args": ["test", "-Dtest=LoginTest"],
      "group": "test"
    },
    {
      "label": "Maven: Run ProductTest",
      "type": "shell",
      "command": "mvn",
      "args": ["test", "-Dtest=ProductTest"],
      "group": "test"
    },
    {
      "label": "Maven: Run CartTest",
      "type": "shell",
      "command": "mvn",
      "args": ["test", "-Dtest=CartTest"],
      "group": "test"
    },
    {
      "label": "Maven: Run CheckoutTest",
      "type": "shell",
      "command": "mvn",
      "args": ["test", "-Dtest=CheckoutTest"],
      "group": "test"
    },
    {
      "label": "Maven: Run ValidationTest",
      "type": "shell",
      "command": "mvn",
      "args": ["test", "-Dtest=ValidationTest"],
      "group": "test"
    },
    {
      "label": "Maven: Run Specific Test Method",
      "type": "shell",
      "command": "mvn",
      "args": ["test", "-Dtest=LoginTest#verifyLogin"],
      "group": "test",
      "prompt": true
    },
    {
      "label": "Maven: Generate Report",
      "type": "shell",
      "command": "mvn",
      "args": ["site"],
      "group": "build"
    },
    {
      "label": "Maven: Compile Only",
      "type": "shell",
      "command": "mvn",
      "args": ["compile"],
      "group": "build"
    },
    {
      "label": "Maven: Skip Tests Build",
      "type": "shell",
      "command": "mvn",
      "args": ["clean", "install", "-DskipTests"],
      "group": "build"
    },
    {
      "label": "Open ExtentReport",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "start", "reports/ExtentReport.html"],
      "windows": {
        "command": "cmd",
        "args": ["/c", "start", "reports/ExtentReport.html"]
      },
      "osx": {
        "command": "open",
        "args": ["reports/ExtentReport.html"]
      },
      "linux": {
        "command": "xdg-open",
        "args": ["reports/ExtentReport.html"]
      },
      "group": "none"
    }
  ]
}
